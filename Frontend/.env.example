# ─────────────────────────────────────────────────────────────────────────────
# CloudSpire Frontend — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. NEVER commit .env — it is already in .gitignore
#   4. Vite ONLY exposes variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Base URL ──────────────────────────────────────────────────────────────
# Points to your backend REST API. No trailing slash.
# Dev:        http://localhost:4000/api/v1
# Production: https://<your-render-app>.onrender.com/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# ── Socket.IO Server URL ───────────────────────────────────────────────────────
# Points to your backend Socket.IO server (no /api/v1 path).
# Must be set in Vercel dashboard for production — used by useSocket.js and TopBar.jsx.
# Dev:        http://localhost:4000
# Production: https://<your-render-app>.onrender.com
VITE_SOCKET_URL=http://localhost:4000

# ── App Config ────────────────────────────────────────────────────────────────
VITE_APP_NAME=CloudSpire
VITE_APP_ENV=development
