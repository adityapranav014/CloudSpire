# ─────────────────────────────────────────────────────────────────────────────
# CloudSpire Backend — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below with your own credentials
#   3. NEVER commit the actual .env file — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────
# Get this from MongoDB Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cloudspire?retryWrites=true&w=majority

# ── Auth / JWT ────────────────────────────────────────────
# Generate a strong random string (min 32 chars) — never use the defaults below
BETTER_AUTH_SECRET=replace-with-random-min-32-char-string
JWT_SECRET=replace-with-random-min-32-char-string-different-from-above

# ── Credentials Encryption ────────────────────────────────
# 64 hex chars (256-bit AES key) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=replace-with-64-hex-character-string

# ── AWS (optional — leave blank to use mock data) ─────────
# IAM user needs: ce:GetCostAndUsage, ec2:Describe*
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# ── Azure (optional — leave blank to use mock data) ───────
# App Registration in Azure AD: Cost Management Reader role
AZURE_TENANT_ID=replace-with-tenant-id
AZURE_CLIENT_ID=replace-with-client-id
AZURE_CLIENT_SECRET=replace-with-client-secret
AZURE_SUBSCRIPTION_ID=replace-with-subscription-id

# ── GCP (optional — leave blank to use mock data) ─────────
# Service account JSON path (relative to backend/)
GCP_SERVICE_ACCOUNT_JSON_PATH=./secrets/gcp-service-account.json

# ── AI / Gemini ───────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace-with-gemini-api-key

# ── Notifications (optional) ──────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# ── AWS S3 for Reports (optional) ─────────────────────────
S3_BUCKET_NAME=replace-with-bucket-name
S3_REGION=us-east-1
