# ─────────────────────────────────────────────────────────────────────────────
# CloudSpire Backend — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below with your own credentials
#   3. NEVER commit the actual .env file — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────
# Get this from MongoDB Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cloudspire?retryWrites=true&w=majority

# ── Auth / JWT ────────────────────────────────────────────
# Generate a strong random string (min 32 chars) — never use the defaults below
BETTER_AUTH_SECRET=replace-with-random-min-32-char-string
JWT_SECRET=replace-with-random-min-32-char-string-different-from-above
JWT_EXPIRES_IN=7d

# ── Frontend (CORS origin whitelist) ──────────────────────
# Set these to the URL(s) of your deployed frontend (no trailing slash).
# CLIENT_URL — primary frontend URL used as the single allowed origin
# CLIENT_URLS — comma-separated list for multiple origins (e.g. Vercel + localhost)
# REQUIRED in production: add your Vercel URL here or CORS will block all frontend requests
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Credentials Encryption ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OR run: node scripts/generateEncryptionKey.js
ENCRYPTION_KEY=replace-with-64-hex-character-string

# ── OAuth ─────────────────────────────────────────────────
# Create apps at each provider's developer console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Redis (required for BullMQ) ───────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── AWS (optional — leave blank to use mock data) ─────────
# IAM user needs: ce:GetCostAndUsage, ec2:Describe*
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# ── Azure (optional — leave blank to use mock data) ───────
# App Registration in Azure AD: Cost Management Reader role
AZURE_TENANT_ID=replace-with-tenant-id
AZURE_CLIENT_ID=replace-with-client-id
AZURE_CLIENT_SECRET=replace-with-client-secret
AZURE_SUBSCRIPTION_ID=replace-with-subscription-id

# ── GCP (optional — leave blank to use mock data) ─────────
# Service account JSON path (relative to backend/)
GCP_SERVICE_ACCOUNT_JSON_PATH=./secrets/gcp-service-account.json

# ── AI / OpenRouter ──────────────────────────────────────
# Powers AI features: dashboard narrative, anomaly explanations.
# Get your key from: https://openrouter.ai/keys
# REQUIRED for AI features — without this, AI endpoints return errors.
OPENROUTER_API_KEY=sk-or-replace-with-real-key

# ── Resend (optional — for email notifications) ───────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_replace-with-real-key

# ── Notifications (optional) ──────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# ── AWS S3 for Reports (optional) ─────────────────────────
S3_BUCKET_NAME=replace-with-bucket-name
S3_REGION=us-east-1
