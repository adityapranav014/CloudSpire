#!/bin/sh
# ─────────────────────────────────────────────────────────
# Git pre-commit hook: Block direct commits to main branch
# Installed by: scripts/setup-hooks.sh
# ─────────────────────────────────────────────────────────

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo ""
  echo "  ╔══════════════════════════════════════════════════╗"
  echo "  ║  🚫 COMMIT BLOCKED — You are on '$branch'       ║"
  echo "  ║                                                  ║"
  echo "  ║  CloudSpire uses feature branches + PRs.         ║"
  echo "  ║  Please create a branch first:                   ║"
  echo "  ║                                                  ║"
  echo "  ║    git checkout -b feature/your-feature-name     ║"
  echo "  ║                                                  ║"
  echo "  ║  See CONTRIBUTING.md for the full workflow.      ║"
  echo "  ╚══════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi
